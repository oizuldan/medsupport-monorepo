{
  "name": "@medsupportkz/web",
  "version": "0.1.0",
  "private": false,
  "description": "Next.js Medsupportkz web application",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/oizuldan/medsupportkz",
    "directory": "apps/web"
  },
  "license": "MIT",
  "files": [
    "src"
  ],
  "scripts": {
    "apollo:clean": "find . -path ./node_modules -prune -o -name '__generated__' -exec rm -rf '{}' \\; || true",
    "apollo:codegen": "dotenv-load apollo client:codegen --includes=**/graphql.ts --target=typescript --passthroughCustomScalars --useReadOnlyTypes",
    "ci": "run-p ci:*",
    "ci:lint": "eslint --cache --max-warnings 0 src",
    "ci:test": "NODE_PATH=src jest --passWithNoTests",
    "ci:tsc": "tsc",
    "web:start": "ts-node -P tsconfig.json src/server.ts",
    "web:start:prod": "NODE_ENV=production ts-node -P tsconfig.json src/server.ts",
    "clean": "yarn apollo:clean",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "compile": "yarn apollo"
  },
  "babel": {
    "presets": [
      "next/babel",
      "@emotion/babel-preset-css-prop"
    ]
  },
  "eslintConfig": {
    "extends": [
      "@azimutlabs"
    ]
  },
  "dependencies": {
    "@emotion/babel-preset-css-prop": "^10.0.27",
    "@emotion/core": "^10.0.28",
    "@emotion/styled": "^10.0.27",
    "@medsupportkz/config": "^0.1.0",
    "@medsupportkz/next": "^0.0.0",
    "@popperjs/core": "^2.9.2",
    "bootstrap-4-grid": "^3.4.0",
    "classnames": "^2.2.6",
    "cogo-toast": "^4.2.3",
    "date-fns": "2.16.1",
    "dotenv-load": "^2.0.0",
    "emotion-rgba": "^0.0.8",
    "express": "^4.17.1",
    "facepaint": "^1.2.1",
    "next": "^9.5.2",
    "next-i18next": "^7.0.1",
    "next-routes": "^1.4.2",
    "normalize.css": "^8.0.1",
    "react": "^16.13.1",
    "react-dom": "^17.0.2",
    "react-modal": "^3.12.1",
    "ts-node": "^8.10.2",
    "axios": "^0.21.0",
    "js-cookie": "^2.2.1",
    "react-dropzone": "^11.3.2",
    "react-markdown": "^6.0.0",
    "react-use-gesture": "^9.1.3",
    "react-spring": "^8.0.27",
    "react-youtube": "7.13.1",
    "mobile-detect": "^1.4.4",
    "socket.io-client": "^4.0.1",
    "react-timeago": "^5.2.0",
    "rehype-raw": "^5.1.0",
    "graphql": "^15.5.0",
    "@apollo/client": "^3.3.19",
    "apollo": "^2.33.4",
    "next-with-apollo": "^5.1.1",
    "tailwindcss": "npm:@tailwindcss/postcss7-compat",
    "postcss": "^7",
    "autoprefixer": "^9",
    "@heroicons/react": "^1.0.3",
    "react-yandex-metrika": "^2.6.0"
  },
  "devDependencies": {
    "@types/dotenv-load": "^2.0.0",
    "@types/socket.io-client": "^1.4.36",
    "@types/js-cookie": "^2.2.6",
    "@types/classnames": "^2.2.10",
    "@types/react-dom": "^17.0.3",
    "@types/react-modal": "^3.12.0",
    "@types/express": "^4.17.6",
    "@types/facepaint": "^1.2.1",
    "@types/node": "^12.12.54",
    "@types/react": "^16.9.36",
    "typescript": "^3.8.3",
    "yarn-run-all": "^3.1.1",
    "fp-ts": "^2.8.1",
    "utility-types": "^3.10.0"
  },
  "deploy": {
    "dotenv": true,
    "publicURL": "/",
    "preset": "next"
  },
  "proxy": "https://medsupport.dev/api",
  "proxy2": "https://drive.google.com/",
  "proxy3": "https://medsupport.dev/cms"
}
