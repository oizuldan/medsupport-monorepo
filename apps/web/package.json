{
  "name": "@medsupportkz/web",
  "version": "0.1.0",
  "private": false,
  "description": "Next.js Medsupportkz web application",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/oizuldan/medsupportkz",
    "directory": "apps/web"
  },
  "license": "MIT",
  "files": [
    "src"
  ],
  "scripts": {
    "ci": "run-p ci:*",
    "ci:lint": "eslint --cache --max-warnings 0 src",
    "ci:test": "NODE_PATH=src jest --passWithNoTests",
    "ci:tsc": "tsc",
    "start": "ts-node -P tsconfig.json src/server.ts",
    "start:prod": "NODE_ENV=production ts-node -P tsconfig.json src/server.ts"
  },
  "babel": {
    "presets": [
      "next/babel",
      "@emotion/babel-preset-css-prop"
    ]
  },
  "eslintConfig": {
    "extends": [
      "@azimutlabs"
    ]
  },
  "dependencies": {
    "@emotion/babel-preset-css-prop": "^10.0.27",
    "@emotion/core": "^10.0.28",
    "@emotion/styled": "^10.0.27",
    "@medsupportkz/config": "^0.1.0",
    "@medsupportkz/next": "^0.0.0",
    "@popperjs/core": "^2.9.2",
    "bootstrap-4-grid": "^3.4.0",
    "classnames": "^2.2.6",
    "cogo-toast": "^4.2.3",
    "date-fns": "2.16.1",
    "dotenv-load": "^2.0.0",
    "emotion-rgba": "^0.0.8",
    "express": "^4.17.1",
    "facepaint": "^1.2.1",
    "next": "^9.5.2",
    "next-i18next": "^7.0.1",
    "next-routes": "^1.4.2",
    "normalize.css": "^8.0.1",
    "react": "^16.13.1",
    "react-dom": "^17.0.2",
    "react-pdf": "^5.1.0",
    "react-modal": "^3.12.1",
    "ts-node": "^8.10.2",
    "axios": "^0.21.0",
    "js-cookie": "^2.2.1",
    "react-markdown": "^6.0.0",
    "react-use-gesture": "^9.1.3",
    "react-spring": "^8.0.27",
    "react-youtube": "7.13.1",
    "rehype-raw": "^5.1.0",
    "mobile-detect": "^1.4.4"
  },
  "devDependencies": {
    "@types/dotenv-load": "^2.0.0",
    "@types/react-pdf": "^5.0.0",
    "@types/js-cookie": "^2.2.6",
    "@types/classnames": "^2.2.10",
    "@types/react-dom": "^17.0.3",
    "@types/react-modal": "^3.12.0",
    "@types/express": "^4.17.6",
    "@types/facepaint": "^1.2.1",
    "@types/node": "^12.12.54",
    "@types/react": "^16.9.36",
    "typescript": "^3.8.3",
    "yarn-run-all": "^3.1.1",
    "fp-ts": "^2.8.1"
  },
  "deploy": {
    "dotenv": true,
    "publicURL": "/",
    "preset": "next"
  },
  "proxy": "http://localhost:8000",
  "proxy2": "https://drive.google.com/",
  "proxy3": "http://localhost:1337"
}
